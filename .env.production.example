# Core runtime
NODE_ENV=production
SESSION_SECRET=replace-with-strong-random-secret
TOKEN_ENC_KEY=replace-with-strong-random-secret
APP_BASE_URL=https://www.auto-ads.co
CRON_SECRET=replace-with-strong-random-secret
ENABLE_DEV_AUTH_BYPASS=false
# Optional (only if enabling debug creative endpoint in production)
DEBUG_CREATIVE_SECRET=

# Database
DATABASE_URL=postgresql://...
SUPABASE_DATABASE_URL=postgresql://...
# Optional: for Supabase pooler / serverless tune lower (e.g. 1-2)
PG_POOL_MAX=1
# Optional: release idle clients faster in serverless (default production: 5000)
PG_IDLE_TIMEOUT_MS=5000
# Optional: connection acquisition timeout in ms (default: 10000)
PG_CONNECTION_TIMEOUT_MS=10000
# Optional: disabled by default in production to avoid heavy DB startup load
DB_STARTUP_MAINTENANCE=false
# Optional: keep true unless table is managed by migrations externally
DB_ENSURE_META_ACCOUNT_CACHE_TABLE=true

# Supabase Storage staging for video uploads
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_STORAGE_BUCKET=meta-staging

# Meta OAuth/API
META_APP_ID=...
META_APP_SECRET=...
META_API_VERSION=v20.0

# Stripe billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY_EUR=price_...
STRIPE_PRICE_YEARLY_EUR=price_...
# Optional absolute URL overrides for checkout/portal redirects
STRIPE_CHECKOUT_SUCCESS_URL=https://www.auto-ads.co/settings?billing=success
STRIPE_CHECKOUT_CANCEL_URL=https://www.auto-ads.co/settings?billing=cancel
STRIPE_PORTAL_RETURN_URL=https://www.auto-ads.co/settings

# Google Drive (service-account only)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Optional AI integrations
OPENAI_API_KEY=...
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
